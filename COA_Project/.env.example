# =============================================================================
# C.O.A — نسخة مثال للمتغيرات البيئية
# انسخ هذا الملف:  cp .env.example .env
# ثم عدّل القيم في .env (لا ترفع .env إلى Git إذا احتوى على مفاتيح حقيقية)
# =============================================================================

# --- مجلس CrewAI: LLM محلي (Ollama) أو Google Gemini ---
# COA_LLM_PROVIDER=ollama   # افتراضي — محلي
# COA_LLM_PROVIDER=gemini   # سحابي — يتطلب مفتاح Gemini (انظر أدناه)
# (القيم openai|external|api|cloud تُعامل مثل gemini — المسار السحابي أصبح Gemini وليس OpenAI.)

# --- وضع محلي (Ollama) — علّق كتلة Gemini أدناه إن استخدمت هذا ---
# COA_LLM_PROVIDER=ollama
# COA_LLM_MODEL=llama3.1
# على Apple Silicon: نموذج أصغر أسرع للمجلس
# COA_LLM_MODEL=llama3.2:3b
# COA_LLM_BASE_URL=http://localhost:11434
# COA_LLM_TEMPERATURE=0.3

# --- وضع Gemini (سحابي) — مفتاح من https://aistudio.google.com/apikey ---
# علّق كتلة Ollama أعلاه إن فعّلت هذا المسار. المفتاح لازم ASCII فقط (لا نص عربي في القيمة).
COA_LLM_PROVIDER=gemini
COA_LLM_MODEL=gemini-2.0-flash
COA_GEMINI_API_KEY=AIza...your_real_key_here...
# أو بدل السطر أعلاه: COA_LLM_API_KEY= / GOOGLE_API_KEY= / GEMINI_API_KEY=
# تثبيت SDK: pip install 'crewai[google-genai]' أو pip install -r requirements.txt
# إن ظهر 429 / RESOURCE_EXHAUSTED: حصّة الطبقة المجانية أو حدّ الطلبات — انتظر وأعد المحاولة، أو COA_LLM_MODEL=gemini-2.0-flash-lite، أو فعّل الفوترة، أو bash scripts/council-local.sh

# بديل: بعض الأدوات تقرأ OLLAMA_HOST (مضيف فقط، بدون http:// أحياناً)
# OLLAMA_HOST=127.0.0.1:11434

# أوامر المجلس (مسارين مختلفين — يتجاهلان .env لهذا التشغيل فقط عند استخدام السكربت أو الـ export):
# محلي (Ollama):
#   bash scripts/council-local.sh
#   أو: cd COA_Project && source venv/bin/activate && COA_LLM_PROVIDER=ollama COA_LLM_MODEL=llama3.1 python main.py --council
# Gemini (المفتاح من .env أو من التصدير):
#   bash scripts/council-gemini.sh
#   أو: cd COA_Project && source venv/bin/activate && COA_LLM_PROVIDER=gemini COA_LLM_MODEL=gemini-2.0-flash GOOGLE_API_KEY="AIza..." python main.py --council

# --- VirusTotal (اختياري — يُفعّل مع: python main.py --vt) ---
# سجّل مجاناً: https://www.virustotal.com/gui/join-us
VT_API_KEY=

# --- مجلس CrewAI (سرعة مرحلة 2.9 / --council) ---
# تقليل التكرارات والبيانات المرسلة لـ Ollama يختصر الوقت بشكل كبير.
# أقصى طول توليد لكل استدعاء LLM (الأثر الأكبر على الوقت بعد حجم النموذج).
# COA_COUNCIL_MAX_OUTPUT_TOKENS=1536
# COA_COUNCIL_LLM_TIMEOUT=300
# COA_COUNCIL_MAX_ITER=2
# COA_COUNCIL_MAX_CONN=12
# COA_COUNCIL_MAX_PROC=15
# COA_COUNCIL_RAW_JSON_MAX=32000
# COA_COUNCIL_THREATS_JSON_MAX=20000
# 1 = طباعة تفصيلية جداً من CrewAI. الافتراضي: إيقاف.
# COA_COUNCIL_VERBOSE=1
# COA_COUNCIL_PROGRESS_EST_SEC=90   # CLI bar time curve; creeps toward ~93% if over estimate; 100% when done

# --- واجهة الويب / تطوير ---
# 1 = أزرار «تشغيل» في صفحة أوامر CLI فقط (بدون pytest)
# COA_ALLOW_CLI_RUN=1
# 1 = pytest من الواجهة + نفس أزرار التشغيل أعلاه
COA_ALLOW_DEV_TESTS=0
